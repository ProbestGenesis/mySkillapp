{
  "expo": {
    "name": "skillmap",
    "slug": "skillmap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "skillmap",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "launchMode": "singleTask",
      "package": "com.genesiscorp.skillmap",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "versionCode": 2
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image",
        {
          "disableLibdav1d": true
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends.",
          "colors": {
            "cropToolbarColor": "#000000"
          },
          "dark": {
            "colors": {
              "cropToolbarColor": "#000000"
            }
          }
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow SKILLMAP to use your location."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#ffffff",
          "defaultChannel": "default",
          "enableBackgroundRemoteNotifications": false
        }
      ],
      "expo-web-browser",
      "expo-font",
      [
        "expo-audio",
        {
          "microphonePermission": "Allow SKILLMAP to access your microphone.",
          "enableBackgroundPlayback": true,
          "enableBackgroundRecording": false
        }
      ],
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "owner": "genesis-corp",
    "extra": {
      "eas": {
        "projectId": "3961fb8c-2232-446f-a414-aad27ecfe046"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/3961fb8c-2232-446f-a414-aad27ecfe046",
      "enable": true,
      "checkAutomatically": "ON_APP_LAUNCH",
      "fallbackToCacheTimeout": 60
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
