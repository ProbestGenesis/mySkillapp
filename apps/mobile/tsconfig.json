{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "importHelpers": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "*"
      ],
      "@lib/*": ["packages/lib/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
  ]
}